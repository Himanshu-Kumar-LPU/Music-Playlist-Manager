# ============================================================================
# Environment Configuration
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# EMAIL & OTP CONFIGURATION (Required for production)
# ============================================================================

# Option 1: Gmail (easiest for development)
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option 2: Custom SMTP Server
# SMTP_HOST=smtp.your-server.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-email@your-domain.com
# EMAIL_PASSWORD=your-password

# ============================================================================
# DEVELOPMENT MODE
# ============================================================================

# Set to 'true' to disable email and log OTP to server console instead
# ONLY for development! Set to 'false' in production
DEV_EMAIL_FALLBACK=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Backend server port (default: 4000)
PORT=4000

# ============================================================================
# FRONTEND CONFIGURATION (Optional)
# ============================================================================

# For production builds, set the backend API URL
# VITE_API_URL=https://your-api-domain.com

# Enable debug mode for development
# VITE_DEBUG_MODE=false
